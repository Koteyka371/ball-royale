                        if a != 0.0:
                            var disc = b2*b2 - 4.0*a*c
                            if disc >= 0.0:
                                disc = sqrt(disc)
                                var t1 = (-b2 - disc) / (2.0*a)
                                var t2 = (-b2 + disc) / (2.0*a)
                                if (t1 >= 0.0 and t1 <= 1.0) or (t2 >= 0.0 and t2 <= 1.0) or (t1 < 0.0 and t2 > 1.0):
