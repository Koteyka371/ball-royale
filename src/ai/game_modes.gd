								var damage = 10.0 * delta
								if b.has_method("take_damage"):
									b.take_damage(damage, "irradiated_zone")
								elif "hp" in b:
									b.hp -= damage
									if b.hp <= 0:
										b.hp = 0
										b.alive = false

