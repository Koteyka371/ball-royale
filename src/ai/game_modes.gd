						if "weather_immunity_timer" in b: b.weather_immunity_timer = t + delta * 2.0
						elif b.has_method("set_meta"): b.set_meta("weather_immunity_timer", t + delta * 2.0)

				if arena_name.find("dirt") != -1 or arena_name.find("earth") != -1:
