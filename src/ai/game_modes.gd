				alive.append(b)

		if alive.size() == 0:
			return "Draw"

		var teams_alive = {}
		for b in alive:
			if "team" in b:
				teams_alive[b.team] = true
			else:
				teams_alive[b.ball_type] = true

		if teams_alive.size() == 1:
			if has_method("_award_skill_points"): call("_award_skill_points")
			return teams_alive.keys()[0]

		if alive.size() == 1:
