					var y = randf_range(100, arena_height - 100)
					var r = randf_range(30.0, 60.0)
					var kind = hazard_kinds[randi() % hazard_kinds.size()]
					var hazard = {"id": 12000 + i, "x": x, "y": y, "radius": r, "kind": kind, "damage": 0.0}
