				elif typeof(h) == TYPE_DICTIONARY:
					var vx = 0.0
					if h.has("vx"): vx = h["vx"]
					var vy = 0.0
					if h.has("vy"): vy = h["vy"]
					var h_duration = 0.0
					if h.has("duration"): h_duration = h["duration"]

