							elif "vy" in other: vy = other.vy

							vx += (dx / d) * pull * 100.0
							vy += (dy / d) * pull * 100.0

							if typeof(other) != TYPE_DICTIONARY and other.has_method("has_meta"):
								other.set_meta("vx", vx)
								other.set_meta("vy", vy)
							elif "vx" in other:
