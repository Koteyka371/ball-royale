			var is_active = true
			var h_x = 0.0
			var h_y = 0.0
			var h_radius = 80.0
			if typeof(h) == TYPE_DICTIONARY:
				h_kind = h.get("kind", "")
				is_active = h.get("active", true)
				h_x = h.get("x", 0.0)
				h_y = h.get("y", 0.0)
				h_radius = h.get("radius", 80.0)
			else:
				h_kind = h.kind if "kind" in h else ""
				if h.has_method("get_meta") and h.has_meta("active"):
